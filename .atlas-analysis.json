  "keyFeatures": [
    "End-to-end type safety with automatic type inference",
    "Optimized for Bun with WinterTC compliance for multi-runtime support",
    "Plugin system with encapsulated lifecycle hooks",
    "Standard Schema support (Zod, Valibot, ArkType, Effect)",
    "Eden type-safe HTTP client (no code generation needed)",
    "Automatic OpenAPI documentation generation",
    "Macro system for reusable route configurations",
    "WebSocket support with type-safe messaging"
  ],
  "publicApiSurface": [
    "new Elysia()",
    ".get() / .post() / .put() / .patch() / .delete() / .route()",
    ".use(plugin)",
    ".listen(port)",
    ".macro()",
    ".onBeforeHandle() / .onAfterHandle() / .onError()",
    ".resolve() / .derive()",
    "t (TypeBox schema builder)",
    "treaty<App>() — Eden type-safe client",
